release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Compiled class files
*.class

# Packaged artifacts
*.jar
*.war
*.ear
# ...but keep the Maven wrapper scripts under version control
!mvnw
!mvnw.cmd
# ...and DO publish the distributable JARs in artifact/ so they ship with the repo.
!artifact/
!artifact/**/*.jar

